Bootstrap: docker
From: rocker/r-ver:4.5.1

%labels
    Author Ian
    Version v1.0
    Description DADA2 container using Bioconductor 3.22 and R 4.5.1

%environment
    export R_LIBS_USER=/usr/local/lib/R/site-library
    export LC_ALL=C
    export LANG=C

%post
    apt-get update && apt-get install -y \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libfontconfig1-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libpng-dev \
        libjpeg-dev \
        libtiff-dev \
        libxt-dev \
        libz-dev \
        libudunits2-dev \
        libgeos-dev \
        libproj-dev \
        libgdal-dev \
        git \
        wget \
        curl \
        ca-certificates \
		python3 \
        python3-pip \
        python3-dev \
		cutadapt

    Rscript -e "if (!requireNamespace('BiocManager', quietly = TRUE)) install.packages('BiocManager', repos='https://cloud.r-project.org')"
    Rscript -e "BiocManager::install('dada2', version = '3.22', update = FALSE, ask = FALSE)"
	Rscript -e "BiocManager::install('DECIPHER', version = '3.22', update = FALSE, ask = FALSE)"
	
	
%runscript
    echo 'Welcome to the DADA2 container!'
    exec R